# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# Telegram user ID(s) администраторов (через запятую)
# Узнать свой ID можно у @userinfobot
ADMIN_IDS=123456789,987654321

# OAuth-токен SoundCloud для скачивания в 320 kbps (требует аккаунт Go+)
# Как получить: браузер → soundcloud.com → DevTools (F12) → Network →
#   любой запрос к api.soundcloud.com → заголовок Authorization → скопировать "OAuth a-xxx-xxx"
# Без токена бот скачивает в 128 kbps (бесплатное качество)
SOUNDCLOUD_OAUTH_TOKEN=
