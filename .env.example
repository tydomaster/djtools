# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# Telegram user ID(s) администраторов (через запятую)
# Узнать свой ID можно у @userinfobot
ADMIN_IDS=123456789,987654321

# ── SoundCloud авторизация (для 320 kbps Go+) ──────────────────────────────
#
# Вариант 1 (рекомендуется): куки из браузера — живут 6-12 месяцев
#   1. Войди в SoundCloud Go+ в браузере
#   2. Установи расширение "Get cookies.txt LOCALLY"
#   3. Экспортируй куки soundcloud.com в файл
#   4. Закодируй: base64 cookies.txt | tr -d '\n'
#   5. Вставь результат ниже
SOUNDCLOUD_COOKIES=

# Вариант 2 (запасной): OAuth токен — живёт месяцами, но короче кук
#   DevTools → Network → любой запрос к api.soundcloud.com → заголовок Authorization
SOUNDCLOUD_OAUTH_TOKEN=

# ── Производительность ─────────────────────────────────────────────────────
# Сколько треков качается одновременно (больше = нужно больше CPU/RAM)
MAX_CONCURRENT_DOWNLOADS=3

# Кэш: одинаковый трек не скачивается повторно в течение этого времени (секунды)
CACHE_TTL_SECONDS=3600

# Rate limit: максимум запросов с одного пользователя за окно
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=3600
